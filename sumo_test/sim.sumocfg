<?xml version="1.0" encoding="UTF-8"?>

<configuration>
    <input>
        <net-file value="network.net.xml"/>
    </input>
    
    <time>
        <begin value="0"/>
        <end value="300"/>
    </time>
    
    <!-- Enable collision detection and simulation (valid for all SUMO versions) -->
    <processing>
        <collision.action value="warn"/> <!-- Options: none, warn, stop, teleport -->
    </processing>
</configuration>
